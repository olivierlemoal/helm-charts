<?xml version="1.0" ?>
<LifecycleConfiguration xmlns="http://s3.amazonaws.com/doc/2006-03-01/">
	<Rule>
		<Expiration>
			<Days>10</Days>
		</Expiration>
		<ID>delete-old-backup</ID>
		<Filter>
			<Prefix/>
			<And>
				<Prefix>history</Prefix>
			</And>
		</Filter>
		<Status>Enabled</Status>
	</Rule>
</LifecycleConfiguration>

